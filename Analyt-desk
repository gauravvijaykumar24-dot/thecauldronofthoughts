<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Analyst's Desk &mdash; The Cauldron of Thoughts</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&amp;family=Cinzel:wght@700;900&amp;family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;1,8..60,300&amp;family=Rajdhani:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"/>
<style>
  :root {
    --ink: #0a0a12;
    --gold: #b8943f;
    --gold-light: #d4af5a;
    --gold-pale: #f5edda;
    --crimson: #7a1c1c;
    --crimson-light: #9b2525;
    --slate: #1a1f2e;
    --slate-mid: #252d42;
    --slate-light: #323c58;
    --off-white: #f8f5ef;
    --muted: #8a8fa8;
    --border: rgba(184,148,63,0.25);
  }

  *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
  html { scroll-behavior: smooth; }

  body {
    font-family: 'Rajdhani', sans-serif;
    background: var(--slate);
    color: var(--off-white);
    overflow-x: hidden;
  }

  /* ─── NAVBAR (identical to main page) ─── */
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 2.5rem;
    height: 68px;
    background: rgba(10,10,18,0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border);
    transition: all 0.35s ease;
  }
  .navbar.scrolled {
    background: rgba(10,10,18,0.98);
    box-shadow: 0 4px 24px rgba(0,0,0,0.5);
  }
  .nav-logo {
    font-family: 'Cinzel', serif;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.05em;
    text-decoration: none;
    white-space: nowrap;
  }
  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    list-style: none;
  }
  .nav-item { position: relative; }
  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(248,245,239,0.8);
    text-decoration: none;
    padding: 0.5rem 1rem;
    transition: color 0.25s;
    cursor: pointer;
  }
  .nav-link:hover,
  .nav-link.active { color: var(--gold); }
  .nav-link .chevron { font-size: 0.65rem; transition: transform 0.25s; display: inline-block; }
  .nav-item:hover .chevron { transform: rotate(180deg); }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px; left: 50%; right: 50%;
    height: 1px;
    background: var(--gold);
    transition: left 0.3s, right 0.3s;
  }
  .nav-link:hover::after,
  .nav-link.active::after { left: 1rem; right: 1rem; }
  .dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    background: rgba(10,10,18,0.97);
    border: 1px solid var(--border);
    min-width: 260px;
    padding: 0.5rem 0;
    opacity: 0;
    visibility: hidden;
    transition: all 0.3s ease;
    pointer-events: none;
    backdrop-filter: blur(16px);
  }
  .nav-item:hover .dropdown {
    opacity: 1;
    visibility: visible;
    transform: translateX(-50%) translateY(0);
    pointer-events: all;
  }
  .dropdown-link {
    display: block;
    padding: 0.65rem 1.5rem;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: rgba(248,245,239,0.75);
    text-decoration: none;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s, padding-left 0.2s;
    border-left: 2px solid transparent;
  }
  .dropdown-link:hover {
    background: rgba(184,148,63,0.08);
    color: var(--gold);
    padding-left: 2rem;
    border-left-color: var(--gold);
  }
  .nav-follow-btn {
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--ink);
    background: var(--gold);
    border: none;
    padding: 0.5rem 1.4rem;
    cursor: pointer;
    transition: background 0.25s, transform 0.15s;
  }
  .nav-follow-btn:hover { background: var(--gold-light); transform: scale(1.04); }
  .nav-follow-btn:active { transform: scale(0.97); }
  .hamburger { display: none; flex-direction: column; gap: 5px; cursor: pointer; padding: 0.4rem; }
  .hamburger span { display: block; width: 22px; height: 1.5px; background: var(--off-white); transition: all 0.3s; }

  /* ─── PAGE HERO BANNER ─── */
  .page-banner {
    position: relative;
    height: 340px;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 0 4vw 3rem;
    overflow: hidden;
    margin-top: 68px;
  }
  .page-banner-bg {
    position: absolute;
    inset: 0;
    background-image: url('https://images.unsplash.com/photo-1526778548025-fa2f459cd5c1?w=1600');
    background-size: cover;
    background-position: center 30%;
    filter: brightness(0.22) saturate(0.5);
  }
  .page-banner-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(10,10,18,0.9) 40%, transparent 100%);
  }
  .page-banner-content {
    position: relative;
    z-index: 2;
  }
  .breadcrumb {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.8rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .breadcrumb a {
    color: rgba(248,245,239,0.45);
    text-decoration: none;
    transition: color 0.2s;
  }
  .breadcrumb a:hover { color: var(--gold); }
  .breadcrumb .sep { color: rgba(184,148,63,0.4); }
  .page-banner h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 900;
    color: var(--gold-light);
    letter-spacing: 0.04em;
    line-height: 1.1;
  }
  .page-banner-rule {
    width: 48px;
    height: 2px;
    background: var(--gold);
    margin-top: 1rem;
  }

  /* ─── MAIN LAYOUT ─── */
  .desk-wrapper {
    max-width: 960px;
    margin: 0 auto;
    padding: 5rem 4vw 6rem;
  }

  /* ─── PROFILE HEADER — photo + name on same line ─── */
  .profile-header {
    display: flex;
    align-items: center;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4rem;
  }

  .profile-photo-frame {
    position: relative;
    flex-shrink: 0;
    width: 200px;
    height: 240px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .profile-photo-frame::after {
    content: '';
    position: absolute;
    top: 10px; left: 10px; right: -10px; bottom: -10px;
    border: 1px solid rgba(184,148,63,0.15);
    z-index: 0;
    pointer-events: none;
  }
  .profile-photo-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(15%) contrast(1.05);
    transition: filter 0.5s, transform 0.6s;
    position: relative;
    z-index: 1;
  }
  .profile-photo-frame:hover img {
    filter: grayscale(0%) contrast(1.08);
    transform: scale(1.04);
  }

  /* Placeholder when no photo is uploaded */
  .profile-photo-placeholder {
    width: 100%;
    height: 100%;
    background: var(--slate-mid);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    position: relative;
    z-index: 1;
  }
  .profile-photo-placeholder i { font-size: 2.8rem; color: rgba(184,148,63,0.25); }
  .profile-photo-placeholder span {
    font-size: 0.62rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(184,148,63,0.3);
    text-align: center;
    padding: 0 1rem;
    line-height: 1.6;
  }

  .profile-identity {
    flex: 1;
  }
  .profile-rank {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold);
    margin-bottom: 0.6rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .profile-rank::before,
  .profile-rank::after {
    content: '';
    display: inline-block;
    width: 24px;
    height: 1px;
    background: var(--gold);
    opacity: 0.5;
  }
  .profile-name {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 900;
    color: var(--gold-light);
    letter-spacing: 0.04em;
    line-height: 1.15;
    text-shadow: 0 0 40px rgba(184,148,63,0.2);
  }
  .profile-retd {
    font-family: 'Source Serif 4', serif;
    font-style: italic;
    font-size: clamp(1rem, 1.6vw, 1.3rem);
    font-weight: 300;
    color: rgba(248,245,239,0.45);
    letter-spacing: 0.08em;
    margin-left: 0.5rem;
  }
  .profile-divider {
    width: 48px;
    height: 2px;
    background: var(--gold);
    margin: 1.2rem 0;
  }
  .profile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .profile-tag {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
    background: rgba(184,148,63,0.08);
    border: 1px solid var(--border);
    padding: 0.28rem 0.75rem;
  }

  /* ─── SINGLE STORY CONTENT SECTION ─── */
  .content-section {
    margin-bottom: 4rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid var(--border);
  }
  .content-section:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .section-label {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--gold-light);
    margin-bottom: 0.5rem;
  }
  .section-heading {
    font-family: 'Cinzel', serif;
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    font-weight: 700;
    color: var(--off-white);
    letter-spacing: 0.02em;
    line-height: 1.2;
  }
  .gold-rule {
    width: 40px;
    height: 2px;
    background: var(--gold);
    margin: 1rem 0 2rem;
  }

  /* ── Content Typography ── */
  .prose {
    font-family: 'Source Serif 4', serif;
    font-size: 1.08rem;
    font-weight: 300;
    line-height: 1.9;
    color: var(--gold-light);
  }
  .prose p { margin-bottom: 1.5rem; }
  .prose p:last-child { margin-bottom: 0; }
  .prose strong {
    font-weight: 400;
    color: var(--gold-light);
  }
  .prose em { font-style: italic; color: rgba(248,245,239,0.6); }

  /* Content placeholder notice */
  .content-placeholder {
    border: 1px dashed rgba(184,148,63,0.3);
    background: rgba(184,148,63,0.04);
    padding: 2.5rem 2rem;
    /*text-align: center;*/
  }
  .content-placeholder i {
    font-size: 2rem;
    color: rgba(184,148,63,0.3);
    margin-bottom: 1rem;
    display: block;
  }
  .content-placeholder p {
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(184,148,63,0.45);
    line-height: 1.8;
  }
  .content-placeholder p span {
    display: block;
    font-weight: 400;
    letter-spacing: 0.06em;
    text-transform: none;
    color: rgba(248,245,239,0.3);
    margin-top: 0.4rem;
    font-size: 0.85rem;
    font-family: 'Source Serif 4', serif;
    font-style: italic;
  }

  /* Pull quote */
  .pull-quote {
    border-left: 3px solid var(--gold);
    padding: 1.2rem 2rem;
    margin: 2.5rem 0;
    background: rgba(184,148,63,0.05);
  }
  .pull-quote p {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-style: italic;
    color: var(--gold-light);
    line-height: 1.65;
    margin: 0;
  }
  .pull-quote cite {
    display: block;
    margin-top: 0.8rem;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
    font-style: normal;
  }

  /* ─── CONTACT SECTION ─── */
  .contact-section {
    background: var(--slate-mid);
    border: 1px solid var(--border);
    padding: 3rem 3rem 3.5rem;
    position: relative;
    overflow: hidden;
  }
  .contact-section::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 200px; height: 200px;
    background: radial-gradient(circle, rgba(184,148,63,0.06) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    margin-top: 2.5rem;
    align-items: start;
  }

  .contact-info-block p {
    font-size: 0.95rem;
    line-height: 1.85;
    color: rgba(248,245,239,0.55);
    margin-bottom: 2rem;
  }

  .contact-direct {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }
  .contact-direct-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.02);
    text-decoration: none;
    transition: border-color 0.25s, background 0.25s, transform 0.2s;
    cursor: pointer;
  }
  .contact-direct-item:hover {
    border-color: var(--gold);
    background: rgba(184,148,63,0.06);
    transform: translateX(4px);
  }
  .contact-direct-item i {
    font-size: 1.1rem;
    color: var(--gold);
    width: 20px;
    flex-shrink: 0;
  }
  .contact-direct-item .cdi-label {
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--muted);
    display: block;
  }
  .contact-direct-item .cdi-value {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--off-white);
    letter-spacing: 0.04em;
  }

  /* Contact Form */
  .contact-form { display: flex; flex-direction: column; gap: 1rem; }

  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  .form-group { display: flex; flex-direction: column; gap: 0.4rem; }
  .form-label {
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .form-input,
  .form-textarea,
  .form-select {
    background: rgba(255,255,255,0.03);
    border: none;
    border-bottom: 1px solid rgba(184,148,63,0.3);
    padding: 0.75rem 0.8rem;
    color: var(--off-white);
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    outline: none;
    transition: border-color 0.25s, background 0.25s;
    width: 100%;
  }
  .form-input::placeholder,
  .form-textarea::placeholder { color: rgba(138,143,168,0.5); }
  .form-input:focus,
  .form-textarea:focus,
  .form-select:focus {
    border-color: var(--gold);
    background: rgba(184,148,63,0.04);
  }
  .form-select option { background: var(--slate); color: var(--off-white); }
  .form-textarea { resize: vertical; min-height: 120px; }

  .form-submit {
    background: var(--gold);
    color: var(--ink);
    border: none;
    padding: 0.9rem 2.4rem;
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    cursor: pointer;
    transition: background 0.25s, transform 0.15s;
    align-self: flex-start;
    margin-top: 0.4rem;
  }
  .form-submit:hover { background: var(--gold-light); transform: scale(1.03); }
  .form-submit:active { transform: scale(0.97); }

  .form-success {
    display: none;
    padding: 1rem 1.4rem;
    border: 1px solid rgba(184,148,63,0.4);
    background: rgba(184,148,63,0.08);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* ─── FOOTER (identical to main page) ─── */
  footer {
    background: var(--ink);
    border-top: 1px solid var(--border);
    padding: 4rem 4vw 2rem;
  }
  .footer-top {
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid var(--border);
  }
  .footer-brand .nav-logo { display: block; font-size: 1.3rem; margin-bottom: 1rem; }
  .footer-brand p { font-size: 0.88rem; line-height: 1.75; color: rgba(248,245,239,0.45); max-width: 240px; }
  .footer-social { display: flex; gap: 0.7rem; margin-top: 1.5rem; }
  .social-icon {
    width: 36px; height: 36px;
    border: 1px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    color: var(--muted);
    font-size: 0.9rem;
    text-decoration: none;
    transition: border-color 0.25s, color 0.25s, background 0.25s, transform 0.2s;
  }
  .social-icon:hover { border-color: var(--gold); color: var(--gold); background: rgba(184,148,63,0.08); transform: translateY(-3px); }
  .footer-col h4 { font-family: 'Cinzel', serif; font-size: 0.75rem; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold); margin-bottom: 1.2rem; }
  .footer-links { list-style: none; }
  .footer-links li { margin-bottom: 0.6rem; }
  .footer-links a { font-size: 0.85rem; color: rgba(248,245,239,0.5); text-decoration: none; letter-spacing: 0.04em; transition: color 0.25s, padding-left 0.25s; display: inline-block; }
  .footer-links a:hover { color: var(--gold-light); padding-left: 6px; }
  .footer-bottom { display: flex; align-items: center; justify-content: space-between; padding-top: 2rem; flex-wrap: wrap; gap: 1rem; }
  .footer-bottom p { font-size: 0.72rem; letter-spacing: 0.06em; color: rgba(248,245,239,0.25); }
  .footer-bottom-links { display: flex; gap: 2rem; list-style: none; }
  .footer-bottom-links a { font-size: 0.72rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(248,245,239,0.35); text-decoration: none; transition: color 0.25s; }
  .footer-bottom-links a:hover { color: var(--gold); }

  /* ─── SCROLL REVEAL ─── */
  .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .reveal.visible { opacity: 1; transform: translateY(0); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 960px) {
    .contact-grid { grid-template-columns: 1fr; gap: 2rem; }
    .footer-top { grid-template-columns: 1fr 1fr; gap: 2rem; }
  }
  @media (max-width: 768px) {
    .hamburger { display: flex; }
    .nav-links { display: none; flex-direction: column; position: fixed; top: 68px; left: 0; right: 0; background: rgba(10,10,18,0.99); padding: 1rem 0 2rem; border-bottom: 1px solid var(--border); }
    .nav-links.open { display: flex; }
    .nav-link { padding: 0.8rem 2rem; font-size: 1rem; }
    .dropdown { position: static; opacity: 1; visibility: visible; transform: none; background: rgba(255,255,255,0.04); pointer-events: all; display: none; }
    .nav-item.open .dropdown { display: block; }
    .nav-follow-btn { display: none; }
    .profile-header { flex-direction: column; align-items: flex-start; gap: 1.8rem; }
    .profile-photo-frame { width: 160px; height: 200px; }
    .form-row { grid-template-columns: 1fr; }
    .contact-section { padding: 2rem 1.4rem; }
  }
  @media (max-width: 480px) {
    .footer-top { grid-template-columns: 1fr; }
    .desk-wrapper { padding: 3rem 5vw 4rem; }
  }
</style>
</head>
<body>

<!-- ═══ NAVBAR ═══ -->
<nav class="navbar" id="navbar">
  <a href="index.html" class="nav-logo">The Cauldron</a>

  <ul class="nav-links" id="navLinks">
    <li class="nav-item"><a href="index.html" class="nav-link">Home</a></li>
    <li class="nav-item"><a href="analysts-desk.html" class="nav-link active">Analyst's Desk</a></li>

    <li class="nav-item">
      <a class="nav-link" href="#">Pillars <span class="chevron">&#9662;</span></a>
      <div class="dropdown">
        <a href="#" class="dropdown-link">Military Strategy &amp; Warfare</a>
        <a href="#" class="dropdown-link">Geopolitical Analysis</a>
        <a href="#" class="dropdown-link">Shivaji &amp; Maratha Strategy</a>
